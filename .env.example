# POSTGRES
POSTGRES_USER=bakeshop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bakeshop

# Nest run locally
DB_HOST=localhost
DB_PORT=5432

# Prisma database connection
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# Nest
PORT=3000
NODE_ENV=development

# Security
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme

# CORS — comma-separated list of allowed origins (local dev only, not needed in Docker)
CORS_ORIGIN=http://localhost:5173

# DEV USERS (used by prisma/seed.ts)
USER1_USERNAME=baker
USER1_PASSWORD=baker123
USER2_USERNAME=manager
USER2_PASSWORD=manager123
USER3_USERNAME=admin
USER3_PASSWORD=admin123
